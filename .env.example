# MeetToo app — public runtime config.
# Copy to `.env` and adjust. Any var prefixed with EXPO_PUBLIC_ is inlined into
# the client bundle by Expo, so do NOT put secrets here.

# Base URL of the MeetToo API (no trailing slash).
# Local dev:  http://localhost:3000
# Production: https://<your-api>.up.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3000
