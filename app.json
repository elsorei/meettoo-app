{
  "expo": {
    "name": "MeetToo",
    "slug": "meettoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "meettoo",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "it.studiorei.meettoo",
      "buildNumber": "1",
      "associatedDomains": ["applinks:REPLACE-WITH-YOUR-API-DOMAIN"]
    },
    "android": {
      "package": "it.studiorei.meettoo",
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1020"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "REPLACE-WITH-YOUR-API-DOMAIN",
              "pathPrefix": "/e"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1020",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ]
  }
}
